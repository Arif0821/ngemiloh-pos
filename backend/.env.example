# ── Database ─────────────────────────────────────────────────────────────
# Direct connection to PostgreSQL (PgBouncer not used in current setup)
DATABASE_URL=postgresql://ngemiloh:${DB_PASSWORD}@postgres:5432/ngemiloh_db
# Direct URL for Prisma Migrate
DIRECT_URL=postgresql://ngemiloh:${DB_PASSWORD}@postgres:5432/ngemiloh_db

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT& Auth ───────────────────────────────────────────────────────────
# WAJIB: Generate secrets unik untuk production
JWT_ACCESS_SECRET=generate-a-unique-secret-here-min-32-chars
JWT_ACCESS_EXPIRES=8h
# Pepper untuk PIN hashing (ubah dari default)
PIN_PEPPER_SECRET=change-this-to-a-unique-pepper-secret
BCRYPT_ROUNDS=12

# ── Midtrans ─────────────────────────────────────────────────────────────
# Environment: sandbox | production
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY_SANDBOX=your-sandbox-server-key
MIDTRANS_SERVER_KEY_PRODUCTION=your-production-server-key
MIDTRANS_CLIENT_KEY_SANDBOX=your-sandbox-client-key
MIDTRANS_CLIENT_KEY_PRODUCTION=your-production-client-key
QRIS_EXPIRY_SECONDS=900

# ── Email (Nodemailer) ───────────────────────────────────────────────────
# Gunakan Gmail App Password (bukan password biasa)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_ALERT_TO=alert-recipient@gmail.com

# ── Storage ──────────────────────────────────────────────────────────────
STORAGE_PATH=/var/storage/ngemiloh
MAX_FILE_SIZE_MB=5

# ── Business Rules ───────────────────────────────────────────────────────
PRICE_DELTA_THRESHOLD_PCT=10
MAX_OFFLINE_QUEUE=500
CASH_DISCREPANCY_ALERT_THRESHOLD=5000
MAX_VOID_PER_10MIN=3
DAILY_REVENUE_TARGET=5000000

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://pos.yourdomain.com
APP_VERSION=3.0.0

# ── Security ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://pos.yourdomain.com,http://localhost:5173
# CSP Midtrans Domains (comma-separated, defaults to sandbox+production)
CSP_MIDTRANS_DOMAINS=https://app.sandbox.midtrans.com,https://app.midtrans.com

# ── CAPTCHA (Google reCAPTCHA v3) ──────────────────────────────────────────
# Currently disabled - enable if needed
CAPTCHA_ENABLED=false
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=
CAPTCHA_SCORE_THRESHOLD=0.5
