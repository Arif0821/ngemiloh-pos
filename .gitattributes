# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.svelte text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Scripts
*.sh text eol=lf

# Docker files (must use LF)
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows specific
*.bat text eol=crlf
*.cmd text eol=crlf