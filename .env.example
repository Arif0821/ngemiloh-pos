# ═══════════════════════════════════════════════════════════════════
# Ngemiloh POS - Environment Configuration Example
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env files to version control!
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════
NODE_ENV=development
TZ=Asia/Jakarta
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════
# DATABASE (Production uses Docker secrets instead)
# ═══════════════════════════════════════════════════════════════════
# DB_PASSWORD=your_secure_password_min_32_chars

# ═══════════════════════════════════════════════════════════════════
# SECURITY SECRETS (Production uses Docker secrets)
# ═══════════════════════════════════════════════════════════════════
# JWT_ACCESS_SECRET=your_secure_jwt_secret_min_48_chars
# PIN_PEPPER_SECRET=your_secure_pin_pepper_min_32_chars
# CSRF_SECRET=your_secure_csrf_secret_min_32_chars

# ═══════════════════════════════════════════════════════════════════
# MIDTRANS PAYMENT GATEWAY
# Get keys from: https://dashboard.midtrans.com
# ═══════════════════════════════════════════════════════════════════
MIDTRANS_ENV=sandbox

# Server Key (use Docker secrets in production)
# MIDTRANS_SERVER_KEY_SANDBOX=your_sandbox_server_key
# MIDTRANS_SERVER_KEY_PRODUCTION=your_production_server_key

# Client Key (safe to use in frontend)
MIDTRANS_CLIENT_KEY_SANDBOX=your_sandbox_client_key
MIDTRANS_CLIENT_KEY_PRODUCTION=your_production_client_key

QRIS_EXPIRY_SECONDS=900

# ═══════════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=noreply@ngemiloh.com
# EMAIL_USER=your_email@gmail.com
# EMAIL_APP_PASSWORD=your_app_password

# Alert recipient
EMAIL_ALERT_TO=admin@ngemiloh.com

# ═══════════════════════════════════════════════════════════════════
# MONITORING & ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════
# SENTRY_DSN=https://example@sentry.io/1234567

# ═══════════════════════════════════════════════════════════════════
# BUSINESS RULES (Configurable Magic Numbers)
# ═══════════════════════════════════════════════════════════════════
# Cash discrepancy tolerance (Rp 5,000 default)
DISCREPANCY_THRESHOLD=5000

# Price delta threshold percentage for order verification (10% default)
PRICE_DELTA_THRESHOLD_PCT=10

# Tax rate (11% for Indonesian VAT)
TAX_RATE=0.11

# Member code generation attempts (10 default)
MEMBER_CODE_MAX_ATTEMPTS=10

# Void fraud detection
# Number of voids within window to trigger alert (3 default)
VOID_FRAUD_COUNT=3
# Time window in milliseconds (600000 = 10 minutes)
VOID_FRAUD_WINDOW_MS=600000

# Auto-close shift grace period in milliseconds (1800000 = 30 minutes)
AUTO_CLOSE_GRACE_MS=1800000
# Auto-close warning time in milliseconds (5400000 = 90 minutes)
AUTO_CLOSE_WARNING_MS=5400000

# Slow query threshold in milliseconds (1000 = 1 second)
SLOW_QUERY_THRESHOLD_MS=1000

# ═══════════════════════════════════════════════════════════════════
# BACKUP SYSTEM
# Schedule: Daily at 02:00 WIB
# ═══════════════════════════════════════════════════════════════════
# Backup directory (inside container)
BACKUP_DIR=/var/backups/ngemiloh

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# Encryption key (REQUIRED for production)
# Generate: openssl rand -base64 32
# BACKUP_ENCRYPTION_KEY=your_64_char_encryption_key_here

# Optional: Cloud upload via rclone
# Format: rclone remote:path (e.g., gdrive:ngemiloh-backups)
# BACKUP_RCLONE_REMOTE=

# Optional: Telegram alerts
# Get bot token from @BotFather
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Webhook alerts
# BACKUP_WEBHOOK_URL=https://your-webhook.com/alert

# ═══════════════════════════════════════════════════════════════════
# FEATURE FLAGS (see docs/red-team-findings.md)
# ═══════════════════════════════════════════════════════════════════
# Set to 'true' to enable, 'false' to disable

# CRITICAL: QRIS expiry enforcement (void expired QRIS orders)
# Default: false - ONLY enable after testing
FEATURE_QRIS_EXPIRY_ENFORCEMENT=false

# HIGH: Silent JWT token refresh (8h instead of 365d for kasir)
# Default: false
FEATURE_JWT_REFRESH=false

# HIGH: Require 4-eyes approval for void transactions
# Default: false
FEATURE_VOID_APPROVAL=false

# MEDIUM: Generate receipt when offline
# Default: true
FEATURE_OFFLINE_RECEIPT=true

# ═══════════════════════════════════════════════════════════════════
# PRODUCTION NOTES
# ═══════════════════════════════════════════════════════════════════
# For production deployments:
# 1. Use Docker secrets in ./secrets/ directory
# 2. Set NODE_ENV=production
# 3. Set FRONTEND_URL to your production domain
# 4. Use real Midtrans keys (not sandbox)
# 5. Configure proper domain with SSL certificate
# 6. Set BACKUP_ENCRYPTION_KEY for encrypted backups
# 7. Read docs/red-team-findings.md before enabling feature flags
