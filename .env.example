# ═══════════════════════════════════════════════════════════════════
# Ngemiloh POS - Environment Configuration Example
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env files to version control!
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════
NODE_ENV=development
TZ=Asia/Jakarta
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════
# DATABASE (Production uses Docker secrets instead)
# ═══════════════════════════════════════════════════════════════════
# DB_PASSWORD=your_secure_password_min_32_chars

# ═══════════════════════════════════════════════════════════════════
# SECURITY SECRETS (Production uses Docker secrets)
# ═══════════════════════════════════════════════════════════════════
# JWT_ACCESS_SECRET=your_secure_jwt_secret_min_48_chars
# PIN_PEPPER_SECRET=your_secure_pin_pepper_min_32_chars
# CSRF_SECRET=your_secure_csrf_secret_min_32_chars

# ═══════════════════════════════════════════════════════════════════
# MIDTRANS PAYMENT GATEWAY
# Get keys from: https://dashboard.midtrans.com
# ═══════════════════════════════════════════════════════════════════
MIDTRANS_ENV=sandbox

# Server Key (use Docker secrets in production)
# MIDTRANS_SERVER_KEY_SANDBOX=your_sandbox_server_key
# MIDTRANS_SERVER_KEY_PRODUCTION=your_production_server_key

# Client Key (safe to use in frontend)
MIDTRANS_CLIENT_KEY_SANDBOX=your_sandbox_client_key
MIDTRANS_CLIENT_KEY_PRODUCTION=your_production_client_key

QRIS_EXPIRY_SECONDS=900

# ═══════════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=noreply@ngemiloh.com
# EMAIL_USER=your_email@gmail.com
# EMAIL_APP_PASSWORD=your_app_password

# Alert recipient
EMAIL_ALERT_TO=admin@ngemiloh.com

# ═══════════════════════════════════════════════════════════════════
# MONITORING & ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════
# SENTRY_DSN=https://example@sentry.io/1234567

# ═══════════════════════════════════════════════════════════════════
# BUSINESS RULES
# ═══════════════════════════════════════════════════════════════════
DISCREPANCY_THRESHOLD=5000
PRICE_DELTA_THRESHOLD_PCT=10

# ═══════════════════════════════════════════════════════════════════
# PRODUCTION NOTES
# ═══════════════════════════════════════════════════════════════════
# For production deployments:
# 1. Use Docker secrets in ./secrets/ directory
# 2. Set NODE_ENV=production
# 3. Set FRONTEND_URL to your production domain
# 4. Use real Midtrans keys (not sandbox)
# 5. Configure proper domain with SSL certificate
