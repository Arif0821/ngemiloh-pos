# ===========================================
# BACKUP SYSTEM CONFIGURATION
# Add these to docker/production.env or .env
# ===========================================

# ===========================================
# Database Backup Settings
# ===========================================

# Backup directory (inside container)
BACKUP_DIR=/var/backups/ngemiloh

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Minimum backup size (KB) - reject if smaller
MIN_BACKUP_SIZE_KB=10

# Maximum compressed backup size (MB) - alert if larger
MAX_BACKUP_SIZE_MB=500

# ===========================================
# Encryption (REQUIRED for production)
# Generate: openssl rand -base64 32
# ===========================================
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_64_char_random_string_here

# ===========================================
# Optional: Cloud Upload via rclone
# ===========================================
# BACKUP_RCLONE_REMOTE=gdrive:ngemiloh-backups
# RCLONE_CONFIG_DIR=/config/rclone

# ===========================================
# Optional: Telegram Alerts
# ===========================================
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ===========================================
# Optional: Webhook Alerts
# ===========================================
# BACKUP_WEBHOOK_URL=https://your-webhook.com/alert
