# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env and fill in actual values
# ===========================================
# WARNING: This file contains production secrets!
# Keep this file SECURE and NEVER commit actual values

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://ngemiloh:CHANGE_ME_SECURE_PASSWORD@postgres:5432/ngemiloh_db
DIRECT_URL=postgresql://ngemiloh:CHANGE_ME_SECURE_PASSWORD@postgres:5432/ngemiloh_db

# ===========================================
# REDIS (WITH PASSWORD for production)
# ===========================================
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===========================================
# SECURITY SECRETS (CRITICAL)
# Generate secure random strings (64+ chars)
# Example: openssl rand -base64 48
# ===========================================
JWT_ACCESS_SECRET=CHANGE_ME_generate_64_char_random_string_here
PIN_PEPPER_SECRET=CHANGE_ME_generate_64_char_random_string_here
CSRF_SECRET=CHANGE_ME_generate_32_char_random_string_here

# ===========================================
# BACKUP SYSTEM
# Schedule: Daily at 02:00 WIB
# ===========================================
# Backup directory
BACKUP_DIR=/var/backups/ngemiloh

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Encryption key (REQUIRED for production)
# Generate: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_64_char_random_string_here

# Optional: Cloud upload via rclone
# BACKUP_RCLONE_REMOTE=gdrive:ngemiloh-backups

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Optional: Webhook alerts
# BACKUP_WEBHOOK_URL=https://your-webhook.com/alert

# ===========================================
# MIDTRANS PAYMENT GATEWAY
# Get from Midtrans Dashboard: https://dashboard.midtrans.com
# ===========================================
MIDTRANS_SERVER_KEY_SANDBOX=your_sandbox_server_key_here
MIDTRANS_CLIENT_KEY_SANDBOX=your_sandbox_client_key_here
MIDTRANS_SERVER_KEY_PRODUCTION=your_production_server_key_here
MIDTRANS_CLIENT_KEY_PRODUCTION=your_production_client_key_here

# ===========================================
# EMAIL (SMTP Configuration)
# For Gmail: Use App Password (not regular password)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=production
FRONTEND_URL=https://your-domain.com
MIDTRANS_ENV=production
JWT_ACCESS_EXPIRES=12h
STORAGE_PATH=/var/storage/ngemiloh
TZ=Asia/Jakarta

# ===========================================
# BUSINESS RULES
# ===========================================
QRIS_EXPIRY_SECONDS=900
DISCREPANCY_THRESHOLD=5000
PRICE_DELTA_THRESHOLD_PCT=10
