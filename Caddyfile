# -- Ngemiloh POS - Caddyfile ----------------------------------
# Caddy akan otomatis mengurus sertifikat SSL (HTTPS) gratis!

# Backend API (ganti domain ini dengan domain Anda nanti)
:80 {
    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    handle /api/* {
        reverse_proxy nestjs-api:3000
    }

    # Proxy untuk file upload (gambar produk)
    handle /storage/* {
        reverse_proxy nestjs-api:3000
    }

    # Webhook routes -> proxy ke NestJS backend
    handle /webhooks/* {
        reverse_proxy nestjs-api:3000
    }

    # Umami Analytics - DISABLED (uncomment umami service in docker-compose.yml to enable)
    # handle /umami/* {
    #     reverse_proxy umami:3000
    # }

    # Semua route lain -> serve frontend static files
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
